rules_version = '2';

// ---------------------------------------------------------------------------
// Reglas de seguridad multi-empresa para MilePay.
// Aislamiento por companyId: un usuario solo accede a documentos cuya
// companyId coincide con la de su documento en `users`. El súper-admin
// (users/{uid}.superAdmin == true) accede a todo.
//
// ROL "driver" (chofer): acceso MUY limitado. Solo puede LEER:
//   - su propio documento en `drivers` (el de su driverId)
//   - sus propios `claims` (donde courier == su driverNombre)
//   - sus propios `payroll` y `driverStats` (donde driverNombre/driverKey == el suyo)
//   NO puede leer invoices, otros drivers, users, companies, managers, settings
//   ni alertEstados. Tampoco puede escribir en ninguna colección de datos.
//
// Desplegar con:  firebase deploy --only firestore:rules
// (o pegar en Firebase Console → Firestore → Reglas)
// ---------------------------------------------------------------------------
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    // Súper-admin por CORREO verificado (respaldo "break-glass"): garantiza el
    // acceso del dueño de la plataforma aunque su doc en `users` tenga cualquier
    // problema. Edita esta lista con tu(s) correo(s) de súper-admin.
    function isSuperEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['gabriele.brandonisio.o@gmail.com'];
    }
    // Súper-admin: por correo (respaldo) o por flag superAdmin==true en su doc.
    function isSuper() {
      return isSuperEmail() || (hasProfile() && userDoc().superAdmin == true);
    }
    function role() {
      return hasProfile() ? userDoc().role : '';
    }
    function isDriver() {
      return role() == 'driver';
    }
    // Personal = staff de la empresa (owner/admin/manager/súper-admin), NO chofer.
    function isStaff(cid) {
      return isSuper() || (hasProfile() && !isDriver() && userDoc().companyId == cid);
    }
    function myCompany() {
      return hasProfile() ? userDoc().companyId : null;
    }
    // Datos "de empresa" (finanzas, agregados): solo staff, NUNCA un chofer.
    function inCompany(cid) {
      return isStaff(cid);
    }
    // Nombre / clave / id del chofer vinculado al usuario (rol driver).
    function myDriverName() {
      return hasProfile() ? userDoc().driverNombre : '';
    }
    function myDriverKey() {
      return hasProfile() ? userDoc().driverKey : '';
    }
    function myDriverId() {
      return hasProfile() ? userDoc().driverId : '';
    }

    // Empresas: solo staff de esa empresa o súper-admin. Escritura súper-admin.
    match /companies/{companyId} {
      allow read: if isStaff(companyId);
      allow create, update, delete: if isSuper();
    }

    // Usuarios: cada uno lee su PROPIO doc. El staff (no chofer) lee los usuarios de
    // su empresa. Un chofer solo puede leer su propio documento.
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isSuper() || (hasProfile() && !isDriver() && myCompany() == resource.data.companyId));
      // Crear / editar / borrar usuarios: SOLO el dueño (o súper-admin) de la empresa.
      // Así un manager no puede cambiar roles ni permisos de nadie.
      allow create, update, delete: if isSuper() || (hasProfile() && role() == 'owner' && myCompany() == request.resource.data.companyId);
      // Excepción: CUALQUIER usuario puede guardar SOLO su preferencia de filtro
      // (prefFiltro) en su propio doc — sin poder tocar rol, permisos, ciudad ni empresa.
      allow update: if signedIn() && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prefFiltro']);
    }

    // Facturas / agregados financieros: solo staff. Un chofer NO puede leerlas.
    match /invoices/{id} {
      allow read: if isStaff(resource.data.companyId);
      allow create: if isStaff(request.resource.data.companyId);
      allow update, delete: if isStaff(resource.data.companyId);
    }

    // Drivers: el staff gestiona todos; un chofer solo LEE su propio doc.
    match /drivers/{id} {
      allow read: if isStaff(resource.data.companyId) || (isDriver() && id == myDriverId());
      allow create: if isStaff(request.resource.data.companyId);
      allow update, delete: if isStaff(resource.data.companyId);
    }

    // Claims: el staff gestiona todos; un chofer solo LEE los suyos (courier == su nombre).
    match /claims/{id} {
      allow read: if isStaff(resource.data.companyId) || (isDriver() && resource.data.courier == myDriverName());
      allow create: if isStaff(request.resource.data.companyId);
      allow update, delete: if isStaff(resource.data.companyId);
    }

    // Nómina: el staff gestiona; un chofer solo LEE la suya (driverNombre == su nombre).
    match /payroll/{id} {
      allow read: if isStaff(resource.data.companyId) || (isDriver() && resource.data.driverNombre == myDriverName());
      allow create: if isStaff(request.resource.data.companyId);
      allow update, delete: if isStaff(resource.data.companyId);
    }

    // Resumen por chofer y semana (para el portal del chofer). El chofer solo lee
    // las filas suyas (driverKey == la suya). Lo escribe el staff al cargar facturas.
    match /driverStats/{id} {
      allow read: if isStaff(resource.data.companyId) || (isDriver() && resource.data.driverKey == myDriverKey());
      allow create: if isStaff(request.resource.data.companyId);
      allow update, delete: if isStaff(resource.data.companyId);
    }

    // Managers (costo de empresa): solo staff.
    match /managers/{id} {
      allow read: if isStaff(resource.data.companyId);
      allow create: if isStaff(request.resource.data.companyId);
      allow update, delete: if isStaff(resource.data.companyId);
    }
    // Estado de alertas: solo staff.
    match /alertEstados/{id} {
      allow read: if isStaff(resource.data.companyId);
      allow create: if isStaff(request.resource.data.companyId);
      allow update, delete: if isStaff(resource.data.companyId);
    }
    // Configuración por empresa: solo staff.
    match /settings/{id} {
      allow read: if isStaff(resource.data.companyId);
      allow create: if isStaff(request.resource.data.companyId);
      allow update, delete: if isStaff(resource.data.companyId);
    }
  }
}
